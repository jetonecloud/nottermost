# Root-level env for local Docker dev

# Used by docker-compose for Postgres init
POSTGRES_DB=nottermost
POSTGRES_USER=nottermost
POSTGRES_PASSWORD=nottermost

# API (apps/api)
API_PORT=4000
API_JWT_SECRET=dev-secret-change-me
API_DATABASE_URL=postgresql://nottermost:nottermost@postgres:5432/nottermost?schema=public
API_REDIS_URL=redis://redis:6379
API_CORS_ORIGIN=http://localhost:3000

# Web (apps/web)
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

